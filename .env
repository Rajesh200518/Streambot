# ── StreamBot Configuration ───────────────────────────────────────────────────

# 1. Get from @BotFather on Telegram
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# 2. Get from https://my.telegram.org → App API
API_ID=YOUR_API_ID_HERE
API_HASH=YOUR_API_HASH_HERE

# 3. Run `python gen_session.py` ONCE to generate this
SESSION_STRING=

# 4. Your public server URL (no trailing slash)
BASE_URL=https://yourapp.railway.app

# 5. Your Telegram user ID (get from @userinfobot)
ADMIN_IDS=YOUR_TELEGRAM_USER_ID
